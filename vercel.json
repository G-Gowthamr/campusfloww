{
  "public": false,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/client/$1"
    },
    {
      "source": "/client/(.*)",
      "destination": "/client/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/client/",
      "permanent": true
    }
  ]
}
