# CampusFlow Backend — Environment Variables
# Copy this to .env and fill in your values
# cp .env.example .env

# MongoDB connection string (required for task persistence)
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/campusflow
# Local:   mongodb://localhost:27017/campusflow
MONGO_URI=mongodb://localhost:27017/campusflow

# n8n webhook URL
N8N_WEBHOOK_URL=http://localhost:5678/webhook/schedule

# Telegram Bot Token (from @BotFather — only needed if running the bot directly)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Express server port
PORT=5000
